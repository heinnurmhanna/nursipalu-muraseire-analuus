# Example environment variables for the data workflow
# Note: noise API URL is hardcoded in src/ingest/ingest_noise.py (no auth required, no override needed)
SCHEDULE_SOURCE_URL=https://mil.ee/wp-content/uploads/training-grounds/training_ground_schedule.json
WEATHER_SOURCE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_LATITUDE=58.0
WEATHER_LONGITUDE=26.0
WEATHER_PARAMETERS=temperature_2m,wind_speed_10m,wind_direction_10m,pressure,precipitation,cloudcover
